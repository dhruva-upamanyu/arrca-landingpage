---
// Logo.astro — the arrca magnifying-glass mark. Inherits color via `style="color:…"`
// or a text-* utility on the parent (paths use currentColor). Pass a size in px.
interface Props { size?: number; }
const { size = 26 } = Astro.props;
---
<svg width={size} height={size} viewBox="-7.5 -8 136 136" style="display:block" aria-hidden="true">
  <circle cx="52" cy="65" r="27" fill="none" stroke="currentColor" stroke-width="9"></circle>
  <path d="M71 84 L95 108" stroke="currentColor" stroke-width="12" stroke-linecap="round"></path>
  <path d="M25 41 Q22 25 40 27 Q52 11 64 27 Q82 25 79 41 Q63 31 52 32 Q41 31 25 41 Z" fill="currentColor"></path>
</svg>
