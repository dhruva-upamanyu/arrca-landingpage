---
import Logo from "./Logo.astro";
const GITHUB = "https://github.com/arrca-ai/otel-k8s-graph";
const links = [
  { href: "/#views", label: "Product" },
  { href: "/#how", label: "How it works" },
  { href: "/#mcp", label: "MCP" },
  { href: "/docs", label: "Docs" },
];
---
<header class="sticky top-0 z-50 border-b border-ink-150 bg-paper/85 backdrop-blur-md">
  <div class="mx-auto flex h-[62px] max-w-[1180px] items-center gap-3.5 px-6 sm:px-8">
    <a href="/" class="flex items-center gap-2.5 text-ink-900 no-underline" aria-label="arrca home">
      <span class="text-ink-900"><Logo size={26} /></span>
      <span class="text-[19px] font-bold tracking-tight">arrca</span>
    </a>
    <span class="flex-1"></span>

    <!-- desktop -->
    <nav class="hidden items-center gap-7 md:flex">
      {links.map((l) => (
        <a href={l.href} class="text-[14.5px] font-medium text-ink-500 no-underline hover:text-ink-900">{l.label}</a>
      ))}
      <a href={GITHUB} class="flex items-center gap-1.5 text-[14.5px] font-medium text-ink-500 no-underline hover:text-ink-900">
        GitHub<span class="text-[11px] text-ink-400">↗</span>
      </a>
      <a href="/docs#quickstart" class="rounded-lg bg-teal-600 px-4 py-2.5 text-[14px] font-semibold text-white no-underline hover:bg-teal-400">Get started</a>
    </nav>

    <!-- mobile toggle -->
    <button id="navToggle" class="md:hidden text-ink-900" aria-label="Toggle menu">
      <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>

  <!-- mobile menu -->
  <div id="mobileMenu" class="hidden flex-col gap-1 border-t border-ink-150 bg-paper px-6 py-3 md:!hidden">
    {links.map((l) => (<a href={l.href} class="py-2 text-sm font-medium text-ink-500 no-underline">{l.label}</a>))}
    <a href={GITHUB} class="py-2 text-sm font-medium text-ink-500 no-underline">GitHub ↗</a>
    <a href="/docs#quickstart" class="py-2 text-sm font-semibold text-teal-600 no-underline">Get started</a>
  </div>
</header>
<script>
  const t = document.getElementById("navToggle");
  const m = document.getElementById("mobileMenu");
  t?.addEventListener("click", () => {
    m?.classList.toggle("hidden");
    m?.classList.toggle("flex");
  });
</script>
