---
import Logo from "./Logo.astro";
const links = [
  { href: "#problem", label: "Problem" },
  { href: "#flows", label: "arrca-flows" },
  { href: "#graphs", label: "arrca-graphs" },
];
---
<header class="sticky top-0 z-20 border-b border-ink-900/[0.08] bg-paper/[0.82] backdrop-blur-md">
  <div class="mx-auto flex max-w-[1160px] items-center justify-between px-6 py-[17px] sm:px-10">
    <a href="/" class="flex items-center gap-[11px] text-ink-900 no-underline" aria-label="arrca home">
      <Logo size={26} />
      <span class="text-[20px] font-semibold tracking-[-0.02em]">arrca</span>
    </a>

    <!-- desktop -->
    <nav class="hidden items-center gap-8 text-[14.5px] text-ink-600 md:flex">
      {links.map((l) => (
        <a href={l.href} class="text-ink-600 no-underline hover:text-ink-900">{l.label}</a>
      ))}
    </nav>

    <!-- mobile toggle -->
    <button id="navToggle" class="text-ink-900 md:hidden" aria-label="Toggle menu">
      <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>

  <!-- mobile menu -->
  <div id="mobileMenu" class="hidden flex-col gap-1 border-t border-ink-900/[0.08] bg-paper px-6 py-3 md:!hidden">
    {links.map((l) => (<a href={l.href} class="py-2 text-sm text-ink-600 no-underline">{l.label}</a>))}
  </div>
</header>
<script>
  const t = document.getElementById("navToggle");
  const m = document.getElementById("mobileMenu");
  t?.addEventListener("click", () => {
    m?.classList.toggle("hidden");
    m?.classList.toggle("flex");
  });
</script>
