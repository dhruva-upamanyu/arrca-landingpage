---
// HowItWorks.astro
const steps = [
  { n: "01", title: "Connect", body: "Deploy the chart and fan your OTel collector's trace spans at it. arrca builds the entity graph — zones, nodes, deployments, endpoints, databases, topics — and the edges between them.", active: true },
  { n: "02", title: "Ask", body: "Point Claude at graph-read over MCP. Ask in plain language — “what breaks if I take down auth?” arrca exposes the graph as tools Claude can call to investigate.", active: false },
  { n: "03", title: "Answer", body: "Claude walks the graph with those tools — subgraphs, flows, dependents — and answers, citing the exact entities and edges it traversed. Query it yourself over REST too.", active: false },
];
---
<section id="how" class="mx-auto max-w-[1180px] px-6 pt-[104px] sm:px-8">
  <div class="font-mono text-[12px] uppercase tracking-[0.1em] text-teal-600">How it works</div>
  <h2 class="mt-3 max-w-[560px] text-[clamp(28px,5vw,38px)] font-bold leading-[1.1] tracking-[-0.02em]">
    From cluster to root cause, in three moves.
  </h2>
  <div class="mt-11 grid grid-cols-1 gap-6 md:grid-cols-3">
    {steps.map((s) => (
      <div class={`pt-[18px] border-t-2 ${s.active ? "border-teal-600" : "border-ink-200"}`}>
        <div class="font-mono text-[13px] text-ink-400">{s.n}</div>
        <div class="mt-2 text-[20px] font-semibold">{s.title}</div>
        <p class="mt-2 text-[15px] leading-[1.6] text-ink-500">{s.body}</p>
      </div>
    ))}
  </div>
</section>
