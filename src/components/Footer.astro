---
import Logo from "./Logo.astro";
const GITHUB = "https://github.com/arrca-ai/otel-k8s-graph";
const EMAIL = "mailto:dhruvaupamanyu93@gmail.com";
---
<footer class="border-t border-ink-150 bg-ink-50">
  <div class="mx-auto flex max-w-[1180px] flex-wrap items-center gap-3.5 px-6 py-9 sm:px-8">
    <span class="text-ink-900"><Logo size={22} /></span>
    <span class="text-[16px] font-bold">arrca</span>
    <span class="hidden text-[13.5px] text-ink-400 sm:inline">Root-cause analysis for Kubernetes + OpenTelemetry · more RCA tools coming</span>
    <span class="flex-1"></span>
    <div class="flex flex-wrap gap-x-[22px] gap-y-1.5 text-[13.5px] text-ink-500">
      <a href="/#views" class="text-ink-500 no-underline hover:text-ink-900">Product</a>
      <a href="/#mcp" class="text-ink-500 no-underline hover:text-ink-900">MCP</a>
      <a href="/docs" class="text-ink-500 no-underline hover:text-ink-900">Docs</a>
      <a href={EMAIL} class="text-ink-500 no-underline hover:text-ink-900">Contact</a>
      <a href={GITHUB} class="text-ink-500 no-underline hover:text-ink-900">GitHub ↗</a>
    </div>
  </div>
</footer>
