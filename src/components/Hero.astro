---
import ProductWindow from "./ProductWindow.astro";
const GITHUB = "https://github.com/arrca-ai/otel-k8s-graph";
---
<section class="mx-auto max-w-[1180px] px-6 pt-[78px] text-center sm:px-8">
  <div class="inline-flex items-center gap-2.5 rounded-full border border-teal-600/25 bg-teal-600/[0.06] px-3.5 py-1.5 font-mono text-[12px] uppercase tracking-[0.08em] text-teal-600">
    <span class="h-[7px] w-[7px] animate-pulse rounded-full bg-teal-600"></span>
    Root-cause analysis · MCP-native
  </div>

  <h1 class="mx-auto mt-6 max-w-[840px] text-[clamp(40px,7vw,62px)] font-bold leading-[1.04] tracking-[-0.025em] text-ink-900">
    Service <span class="text-teal-600">graph</span><br />on steroids.
  </h1>

  <p class="mx-auto mt-[22px] max-w-[660px] text-[clamp(17px,2.4vw,19.5px)] leading-[1.55] text-ink-500">
    arrca builds a live relationship graph of your Kubernetes cluster — from read-only APIs and the
    OpenTelemetry traces you already emit. Explore it over REST, or let Claude navigate it over MCP.
  </p>

  <div class="mt-[30px] flex flex-wrap justify-center gap-3.5">
    <a href="/docs#quickstart" class="rounded-[10px] bg-teal-600 px-6 py-3.5 text-[15.5px] font-semibold text-white no-underline shadow-[0_1px_2px_rgba(13,148,136,.3)] hover:bg-teal-400">Get started</a>
    <a href={GITHUB} class="rounded-[10px] border border-ink-200 bg-white px-6 py-3.5 text-[15.5px] font-semibold text-ink-900 no-underline hover:border-ink-400">View on GitHub →</a>
  </div>

  <div class="mt-5 font-mono text-[13px] text-ink-400">
    read-only k8s APIs · OTel trace spans · REST · MCP
  </div>
</section>

<ProductWindow />
