---
const GITHUB = "https://github.com/arrca-ai/otel-k8s-graph";
---
<section
  id="top"
  class="border-b border-ink-150"
  style="background-image:radial-gradient(#e1e7ec 1px, transparent 1px); background-size:24px 24px;"
>
  <div class="mx-auto grid max-w-[1180px] items-center gap-16 px-8 py-24 lg:grid-cols-[1.05fr_0.95fr]">
    <!-- copy -->
    <div>
      <div class="mb-7 inline-flex items-center gap-2.5 font-mono text-[12px] tracking-wide text-ink-400">
        <span class="h-[7px] w-[7px] rounded-full bg-teal-400"></span>
        root-cause analysis · kubernetes
      </div>
      <h1 class="text-[clamp(40px,6vw,68px)] font-bold leading-[0.98] tracking-[-0.035em]">
        <span class="text-teal-600">X</span> marks the<br />root cause.
      </h1>
      <p class="mt-7 max-w-[42ch] text-[18px] leading-relaxed text-ink-500">
        arrca builds a live relationship graph of your Kubernetes cluster — from read-only APIs
        and the OpenTelemetry traces you already emit. Explore it yourself, or let Claude
        navigate it for you.
      </p>
      <div class="mt-9 flex flex-wrap items-center gap-3.5">
        <a href="/#quickstart" class="rounded-[9px] bg-ink-900 px-6 py-3 text-[15px] font-medium text-paper transition-colors hover:bg-ink-800">Get started</a>
        <a href={GITHUB} class="inline-flex items-center gap-2 px-2 py-3 text-[15px] font-medium text-ink-900">
          View on GitHub <span class="text-ink-400">&#8599;</span>
        </a>
      </div>
      <div class="mt-9 flex flex-wrap gap-2 font-mono text-[12.5px] text-ink-400">
        <span>read-only k8s APIs</span><span class="text-ink-200">·</span>
        <span>OTel spans</span><span class="text-ink-200">·</span>
        <span>REST</span><span class="text-ink-200">·</span>
        <span>MCP</span>
      </div>
    </div>

    <!-- product artifact: blast-radius graph -->
    <div class="overflow-hidden rounded-2xl border border-night-line bg-night shadow-[0_30px_60px_-34px_rgba(15,28,40,0.6)]">
      <div class="flex items-center justify-between border-b border-white/10 px-[18px] py-3.5">
        <span class="font-mono text-[12.5px] text-[#9fb0bd]">get_subgraph(prod/auth-service)</span>
        <span class="h-2 w-2 rounded-full bg-teal-400 shadow-[0_0_0_4px_rgba(20,184,166,0.18)]"></span>
      </div>
      <div class="px-5 pb-2 pt-[22px]">
        <svg viewBox="0 0 380 250" class="block w-full">
          <g stroke="#14b8a6" stroke-width="1.4" stroke-opacity="0.55" fill="none">
            <path d="M70,125 L180,52"/><path d="M70,125 L196,120"/><path d="M70,125 L176,196"/>
            <path d="M180,52 L300,40"/><path d="M196,120 L304,96"/><path d="M196,120 L300,150"/><path d="M176,196 L296,208"/>
          </g>
          <circle cx="180" cy="52" r="9" fill="#14b8a6"/>
          <circle cx="196" cy="120" r="9" fill="#14b8a6"/>
          <circle cx="176" cy="196" r="9" fill="#14b8a6"/>
          <circle cx="300" cy="40" r="8" fill="#14b8a6"/>
          <circle cx="304" cy="96" r="8" fill="#14b8a6"/>
          <rect x="293" y="143" width="15" height="15" rx="3.5" fill="#fbfcfd"/>
          <rect x="289" y="201" width="15" height="15" rx="3.5" fill="#fbfcfd"/>
          <rect x="332" y="92" width="13" height="13" rx="2" fill="#f2bb45" transform="rotate(45 338.5 98.5)"/>
          <circle cx="70" cy="125" r="17" fill="#11202e" stroke="#14b8a6" stroke-width="2"/>
          <path d="M63,118 L77,132 M77,118 L63,132" stroke="#14b8a6" stroke-width="2.4" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="flex gap-[18px] px-5 pb-5 pt-2.5 font-mono text-[11.5px] text-[#7f93a1]">
        <span><span class="text-teal-400">7</span> services</span>
        <span><span class="text-paper">2</span> databases</span>
        <span><span class="text-gold-400">1</span> topic</span>
      </div>
    </div>
  </div>
</section>
