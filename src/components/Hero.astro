---
// Hero.astro — headline + the live arrca-ui product screenshot.
---
<section class="px-6 pt-24 pb-16 text-center sm:px-10">
  <div class="mx-auto max-w-[900px]">
    <div class="mb-[26px] font-mono text-[12.5px] tracking-[0.14em] text-accent">arrca · RCA FOR KUBERNETES</div>
    <h1 class="mx-auto mb-5 max-w-[760px] text-[clamp(30px,5vw,42px)] font-semibold leading-[1.18] tracking-[-0.025em] text-ink-900">
      A continuously-updated topology of your Kubernetes estate built from the k8s API and OTel metrics and traces.
    </h1>
    <p class="mx-auto max-w-[600px] text-[18px] leading-[1.6] text-ink-600">
      Install the arrca Helm chart and point your otel-collector at it. Zero setup overhead.
    </p>
  </div>

  <!-- hero product screenshot -->
  <div class="mx-auto mt-[60px] max-w-[1040px]">
    <div class="overflow-hidden rounded-[16px] border border-ink-900/[0.14] bg-paper-2 shadow-[0_40px_80px_-44px_rgba(20,40,58,.50)]">
      <div class="flex items-center justify-between border-b border-ink-900/10 px-[18px] py-[13px]">
        <span class="font-mono text-[11.5px] tracking-[0.05em] text-ink-400">arrca-ui</span>
        <span class="font-mono text-[11px] text-ink-300">●&nbsp;●&nbsp;●</span>
      </div>
      <img
        src="/arrca-flows-screenshot.png"
        alt="arrca-ui Flows view — trace-variant triage worklist with error rates, volumes and inline latency sparklines"
        width="1040"
        class="block w-full"
        loading="lazy"
      />
    </div>
  </div>
</section>
