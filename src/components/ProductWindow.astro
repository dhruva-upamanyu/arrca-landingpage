---
// ProductWindow.astro — hero product mockup with Topology / Flow tabs.
// A marketing mockup of the real graph (topology + canonical flows), not the product itself.
// Tab switching is handled by the inline <script> (vanilla, no framework).

const flowSteps = [
  { name: "frontend-web", op: "entry", opColor: "#8593a0" },
  { name: "checkout-svc", op: "CALLS", opColor: "#11202e" },
  { name: "cart-service", op: "QUERIES", opColor: "#0d9488" },
  { name: "checkout-svc", op: "PUBLISHES", opColor: "#c2730f" },
  { name: "payment-svc", op: "CALLS", opColor: "#11202e" },
];

const tabBase = "pw-tab cursor-pointer rounded-[7px] border px-3 py-[5px] font-mono text-[12px]";
const navBase = "pw-nav flex items-center gap-2 rounded-[7px] px-[9px] py-[7px] text-[12.5px]";
---

<div class="mx-auto mt-[54px] max-w-[1180px] px-6 sm:px-8">
  <!-- tabs -->
  <div class="mb-3.5 flex items-center justify-center gap-[7px]">
    <span class={tabBase} data-view="topology">Topology</span>
    <span class={tabBase} data-view="flow">Flow</span>
  </div>

  <div class="relative h-[520px] overflow-hidden rounded-[16px] border border-ink-150 bg-white shadow-[0_30px_70px_-28px_rgba(17,32,46,.32),0_2px_8px_rgba(17,32,46,.05)]">
    <!-- titlebar -->
    <div class="flex items-center gap-2.5 border-b border-ink-100 bg-ink-50 px-4 py-[11px]">
      <span class="flex gap-1.5">
        <span class="h-[11px] w-[11px] rounded-full bg-ink-200"></span>
        <span class="h-[11px] w-[11px] rounded-full bg-ink-200"></span>
        <span class="h-[11px] w-[11px] rounded-full bg-ink-200"></span>
      </span>
      <span class="ml-1.5 font-mono text-[12px] text-ink-400">arrca · get_subgraph(prod/cart-service)</span>
      <span class="flex-1"></span>
      <span class="inline-flex items-center gap-1.5 rounded-full border border-teal-600/25 bg-teal-600/[0.06] px-2.5 py-[3px] font-mono text-[11px] text-teal-600">
        <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-teal-600"></span>MCP live
      </span>
    </div>

    <div class="flex h-[475px]">
      <!-- nav rail -->
      <div class="hidden w-[148px] flex-none flex-col gap-[3px] border-r border-ink-100 bg-ink-50 px-[9px] py-3 sm:flex">
        <div class="px-2 pb-1.5 pt-[3px] font-mono text-[9.5px] tracking-[0.06em] text-ink-400">VIEWS</div>
        <div class={navBase} data-nav="topology">
          <span class="relative h-[13px] w-[13px]"><span class="absolute left-0 top-0 h-[5px] w-[5px] rounded-full bg-current"></span><span class="absolute right-0 top-[3px] h-[5px] w-[5px] rounded-full bg-current"></span><span class="absolute bottom-0 left-[2px] h-[5px] w-[5px] rounded-full bg-current"></span></span>Topology
        </div>
        <div class={navBase} data-nav="flow">
          <span class="inline-flex h-[11px] w-[14px] items-center gap-[1.5px]"><span class="h-[8px] w-[4px] rounded-[1.5px] border-[1.4px] border-current"></span><span class="h-[1.4px] w-[3px] bg-current"></span><span class="h-[8px] w-[4px] rounded-[1.5px] border-[1.4px] border-current"></span></span>Flow
        </div>
      </div>

      <div class="relative min-w-0 flex-1">
        <!-- TOPOLOGY (single SVG so edges + nodes share one coordinate space) -->
        <div class="pw-panel absolute inset-0 [background:radial-gradient(circle_at_1px_1px,#eef1f3_1px,transparent_0)] [background-size:22px_22px]" data-panel="topology">
          <svg viewBox="0 0 760 475" preserveAspectRatio="xMidYMid meet" class="absolute inset-0 h-full w-full" style="font-family:var(--font-sans)">
            <!-- edges -->
            <line x1="210" y1="150" x2="298" y2="220" stroke="#11202e" stroke-width="2"></line>
            <line x1="470" y1="218" x2="556" y2="118" stroke="#0d9488" stroke-width="2"></line>
            <line x1="470" y1="246" x2="556" y2="348" stroke="#e0892a" stroke-width="2" stroke-dasharray="5 4"></line>
            <line x1="298" y1="250" x2="210" y2="338" stroke="#aeb8c2" stroke-width="1.6" stroke-dasharray="3 4"></line>
            <!-- edge labels -->
            <text x="232" y="180" font-family="JetBrains Mono, monospace" font-size="11" fill="#11202e">CALLS</text>
            <text x="500" y="158" font-family="JetBrains Mono, monospace" font-size="11" fill="#0d9488">QUERIES</text>
            <text x="486" y="300" font-family="JetBrains Mono, monospace" font-size="11" fill="#c2730f">PUBLISHES</text>
            <text x="214" y="302" font-family="JetBrains Mono, monospace" font-size="11" fill="#8593a0">RUNS_IN</text>

            <!-- frontend -->
            <g>
              <rect x="60" y="118" width="150" height="46" rx="9" fill="#fff" stroke="#e7ebee"></rect>
              <rect x="74" y="134" width="14" height="14" rx="3" fill="#3b6cf0"></rect>
              <text x="98" y="139" font-size="13" font-weight="600" fill="#11202e">frontend</text>
              <text x="98" y="153" font-size="9.5" fill="#8593a0">deployment</text>
            </g>
            <!-- cart-service (root) -->
            <g>
              <rect x="298" y="206" width="172" height="50" rx="9" fill="#fff" stroke="#0d9488" stroke-width="1.6"></rect>
              <rect x="312" y="224" width="14" height="14" rx="3" fill="#3b6cf0"></rect>
              <text x="336" y="229" font-size="13" font-weight="600" fill="#11202e">cart-service</text>
              <text x="336" y="243" font-size="9.5" fill="#8593a0">deployment · 9 rps</text>
            </g>
            <!-- cart-db -->
            <g>
              <rect x="556" y="92" width="150" height="46" rx="9" fill="#fff" stroke="#e7ebee"></rect>
              <circle cx="577" cy="115" r="7" fill="#0e9f8e"></circle>
              <text x="594" y="111" font-size="13" font-weight="600" fill="#11202e">cart-db</text>
              <text x="594" y="125" font-size="9.5" fill="#8593a0">postgres</text>
            </g>
            <!-- cart.events -->
            <g>
              <rect x="556" y="328" width="162" height="46" rx="9" fill="#fff" stroke="#e7ebee"></rect>
              <rect x="570" y="344" width="14" height="14" rx="4" fill="#e0892a"></rect>
              <text x="594" y="347" font-size="13" font-weight="600" fill="#11202e">cart.events</text>
              <text x="594" y="361" font-size="9.5" fill="#8593a0">kafka topic</text>
            </g>
            <!-- K8S-04 node -->
            <g>
              <rect x="70" y="328" width="140" height="46" rx="9" fill="#fff" stroke="#e7ebee"></rect>
              <rect x="84" y="345" width="14" height="12" rx="3" fill="none" stroke="#64748b" stroke-width="2" stroke-dasharray="3 2"></rect>
              <text x="108" y="347" font-size="13" font-weight="600" fill="#11202e">K8S-04</text>
              <text x="108" y="361" font-size="9.5" fill="#8593a0">node</text>
            </g>
          </svg>
        </div>

        <!-- FLOW -->
        <div class="pw-panel absolute inset-0 hidden flex-col gap-3 overflow-hidden p-4" data-panel="flow">
          <div class="overflow-hidden rounded-[11px] border border-ink-150 bg-white">
            <div class="flex items-center gap-2.5 border-b border-ink-100 px-3.5 py-[9px]"><span class="h-2 w-2 rounded-full bg-[#1f9d57]"></span><span class="text-[12.5px] font-semibold">flow 1</span><span class="rounded-full bg-[#eef9f1] px-2 py-px text-[10.5px] font-medium text-[#1f9d57]">happy path</span><span class="flex-1"></span><span class="font-mono text-[10px] text-ink-400">5 steps · 1 db</span></div>
            <div class="flex items-center gap-[7px] overflow-x-auto p-3.5">
              {flowSteps.map((s, i) => (
                <div class="flex items-center gap-[7px]">
                  {i > 0 && <span class="text-[14px] text-ink-200">→</span>}
                  <div class="w-[118px] flex-none rounded-[9px] border border-ink-150 bg-white px-[9px] py-[7px]">
                    <div class="mb-px flex items-center gap-[5px]"><span class="h-[9px] w-[9px] flex-none rounded-[2px] bg-[#3b6cf0]"></span><span class="truncate text-[11px] font-semibold">{s.name}</span></div>
                    <div class="mt-[3px] font-mono text-[9.5px] font-semibold" style={`color:${s.opColor}`}>{s.op}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="overflow-hidden rounded-[11px] border border-ink-150 bg-white opacity-95">
            <div class="flex items-center gap-2.5 border-b border-ink-100 px-3.5 py-[9px]"><span class="h-2 w-2 rounded-full bg-[#e0892a]"></span><span class="text-[12.5px] font-semibold">flow 2</span><span class="rounded-full bg-[#fdf3e9] px-2 py-px text-[10.5px] font-medium text-[#c2730f]">cart-empty</span><span class="flex-1"></span><span class="font-mono text-[10px] text-ink-400">2 steps · early return</span></div>
            <div class="flex items-center gap-[7px] overflow-x-auto p-3.5">
              <div class="w-[118px] flex-none rounded-[9px] border border-ink-150 bg-white px-[9px] py-[7px]"><div class="flex items-center gap-[5px]"><span class="h-[9px] w-[9px] flex-none rounded-[2px] bg-[#3b6cf0]"></span><span class="text-[11px] font-semibold">frontend-web</span></div><div class="mt-[3px] font-mono text-[9.5px] font-semibold text-ink-400">entry</div></div>
              <span class="text-[14px] text-ink-200">→</span>
              <div class="w-[118px] flex-none rounded-[9px] border border-ink-150 bg-white px-[9px] py-[7px]"><div class="flex items-center gap-[5px]"><span class="h-[9px] w-[9px] flex-none rounded-[2px] bg-[#3b6cf0]"></span><span class="text-[11px] font-semibold">checkout-svc</span></div><div class="mt-[3px] font-mono text-[9.5px] font-semibold text-[#1f9d57]">409 return</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Tab + nav switching for the hero product window (no framework).
  const tabs = document.querySelectorAll<HTMLElement>(".pw-tab");
  const navs = document.querySelectorAll<HTMLElement>(".pw-nav");
  const panels = document.querySelectorAll<HTMLElement>(".pw-panel");
  const ACTIVE_TAB = ["bg-teal-600", "text-white", "border-teal-600"];
  const IDLE_TAB = ["bg-white", "text-ink-500", "border-ink-200"];
  const ACTIVE_NAV = ["bg-teal-600/10", "text-teal-600", "font-semibold"];
  const IDLE_NAV = ["text-ink-500", "font-medium"];

  function show(view: string) {
    tabs.forEach((t) => {
      const on = t.dataset.view === view;
      t.classList.remove(...ACTIVE_TAB, ...IDLE_TAB);
      t.classList.add(...(on ? ACTIVE_TAB : IDLE_TAB));
    });
    navs.forEach((n) => {
      const on = n.dataset.nav === view;
      n.classList.remove(...ACTIVE_NAV, ...IDLE_NAV);
      n.classList.add(...(on ? ACTIVE_NAV : IDLE_NAV));
    });
    panels.forEach((p) => {
      const on = p.dataset.panel === view;
      p.classList.toggle("hidden", !on);
      if (p.dataset.panel === "flow") p.classList.toggle("flex", on);
    });
  }
  tabs.forEach((t) => t.addEventListener("click", () => show(t.dataset.view!)));
  show("topology");
</script>
