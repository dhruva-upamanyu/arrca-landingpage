---
// CTA.astro
const GITHUB = "https://github.com/arrca-ai/otel-k8s-graph";
---
<section id="get-started" class="mx-auto max-w-[1180px] px-6 py-24 text-center sm:px-8">
  <h2 class="mx-auto max-w-[620px] text-[clamp(30px,5.5vw,42px)] font-bold leading-[1.08] tracking-[-0.025em]">
    Stop grepping dashboards.<br />Start asking.
  </h2>
  <p class="mx-auto mt-[18px] max-w-[520px] text-[18px] leading-[1.55] text-ink-500">
    Point arrca at your cluster, fan it your traces, and let Claude walk the graph.
  </p>
  <div class="mt-7 flex flex-wrap justify-center gap-3.5">
    <a href="/docs#quickstart" class="rounded-[10px] bg-teal-600 px-[26px] py-3.5 text-[15.5px] font-semibold text-white no-underline shadow-[0_1px_2px_rgba(13,148,136,.3)] hover:bg-teal-400">Get started</a>
    <a href="/docs" class="rounded-[10px] border border-ink-200 bg-white px-[26px] py-3.5 text-[15.5px] font-semibold text-ink-900 no-underline hover:border-ink-400">Read the docs →</a>
  </div>
</section>
